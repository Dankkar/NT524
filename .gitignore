# --- ModSecurity & ML ---
# Không nên push bộ luật CRS (nặng và nên clone riêng)
modsec-learn/coreruleset/

# Không nên push các kết quả thử nghiệm (PDF, PNG)
modsec-learn/data/figures/*.pdf
modsec-learn/data/figures/*.png

# Không nên push các file model lớn (tùy chọn)
# modsec-learn/data/models/*.joblib
*.pkl
*.joblib
*.onnx
*.h5
mlruns/
mlartifacts/

# Loại bỏ các file dataset thô (thường rất nặng)
modsec-learn/data/dataset/*.json
*.csv
*.parquet
*.ndjson
# Ngoại trừ các file cấu hình quan trọng
!modsec-learn/data/crs_sqli_ids_4.0.0.json
!modsec-learn/data/crs_sqli_weights_4.0.0.json

