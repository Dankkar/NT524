input {
  beats {
    host => "0.0.0.0"
    port => {{ logstash_port }}
    ecs_compatibility => disabled
  }
}

filter {
  mutate {
    add_field => {
      "siem_pipeline" => "hybrid-filebeat"
    }
  }
}

output {
  elasticsearch {
    hosts => ["http://{{ elasticsearch_host }}:{{ elasticsearch_port }}"]
    index => "siem-hybrid-%{+YYYY.MM.dd}"
  }
}
