# Copy this file to terraform.tfvars and replace values with IDs from your AWS account.
# terraform.tfvars is ignored by git because it is environment-specific.

aws_region = "ap-southeast-1"

# Existing VPC where the WAF and VPN EC2 instances will be created.
vpc_id = "vpc-CHANGE_ME"

# Existing public subnet in the VPC above.
# The subnet route table should have a default route to an Internet Gateway.
subnet_id = "subnet-CHANGE_ME"

# Route table associated with the selected public subnet.
# Terraform will add the route to the OpenStack app CIDR through the AWS VPN ENI here.
route_table_id = "rtb-CHANGE_ME"

# OpenStack App subnet routed through WireGuard.
openstack_app_cidr = "10.0.1.0/24"

# Real WAN/NAT public IP of the laptop/OpenStack AIO host as seen from the Internet.
# Do not use the OpenStack floating IP 172.10.10.x here.
# Example: openstack_vpn_public_cidr = "203.0.113.10/32"
openstack_vpn_public_cidr = "CHANGE_ME_PUBLIC_WAN_IP/32"

# Public key imported to AWS as the EC2 key pair named aws_vpn_key.
public_key_path = "~/.ssh/aws_vpn_key.pub"

# Optional lab Route 53 failover DNS.
route53_failover_enabled      = false
route53_create_hosted_zone    = true
route53_zone_name             = "hybrid-lab.test"
route53_record_name           = "app"
route53_secondary_gateway_ip  = "CHANGE_ME_OPENSTACK_GATEWAY_IP"
route53_health_check_path     = "/healthz"

# Optional Cognito Hosted UI for oauth2-proxy on the cloud gateways.
cognito_enabled          = true
cognito_user_pool_name   = "hybrid-auth-users"
cognito_app_client_name  = "hybrid-auth-gateway"
cognito_domain_prefix    = "CHANGE_ME_UNIQUE_COGNITO_DOMAIN_PREFIX"
